# ============================================================
# Accu-MK1 Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# ============================================================

# --- JWT Authentication ---
# Secret key for signing JWT tokens.
# IMPORTANT: Generate a strong random value for production!
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-in-production

# --- Accu-Mk1 Database (PostgreSQL) ---
# App's own database for users, peptides, calibration curves, wizard sessions, etc.
# Local: points to Docker-hosted PostgreSQL
# Production: DigitalOcean Managed Database
MK1_DB_HOST=localhost
MK1_DB_PORT=5432
MK1_DB_NAME=accumark_mk1
MK1_DB_USER=postgres
MK1_DB_PASSWORD=accumark_dev_secret

# --- API Key (Explorer / Integration Service Endpoints) ---
# Used by the backend to authenticate X-API-Key header requests.
# The frontend no longer manages this — it lives here server-side.
# In production, set to a secure random value.
ACCU_MK1_API_KEY=ak_dev_accumark_2024

# --- Integration Service HTTP API ---
# URL for proxying explorer requests to the Integration Service.
# The ACCU_MK1_API_KEY above is sent as X-API-Key to the integration service.
# Local Docker: http://host.docker.internal:8000
# Production: https://your-integration-service-url.example.com
INTEGRATION_SERVICE_URL=http://host.docker.internal:8000

# --- Active Environment ---
# Controls which Integration Service database to connect to.
# Options: "local" or "production"
INTEGRATION_DB_ENV=local

# ============================================================
# Integration Service Database — Local Development (Docker)
# ============================================================
INTEGRATION_DB_LOCAL_HOST=localhost
INTEGRATION_DB_LOCAL_PORT=5432
INTEGRATION_DB_LOCAL_NAME=accumark_integration
INTEGRATION_DB_LOCAL_USER=postgres
INTEGRATION_DB_LOCAL_PASSWORD=accumark_dev_secret
WORDPRESS_LOCAL_HOST=https://accumarklabs.local

# ============================================================
# Integration Service Database — Production
# ============================================================
INTEGRATION_DB_PROD_HOST=your-production-db-host.example.com
INTEGRATION_DB_PROD_PORT=25060
INTEGRATION_DB_PROD_NAME=accumark_integration
INTEGRATION_DB_PROD_USER=your_db_user
INTEGRATION_DB_PROD_PASSWORD=your_db_password
WORDPRESS_PROD_HOST=https://accumarklabs.com

# ============================================================
# Peptide / Compound Request Feature
# ============================================================
# ClickUp personal API token (pk_...). Create one at:
#   https://app.clickup.com/<workspace>/settings/apps
CLICKUP_API_TOKEN=
# List ID from the URL of the ClickUp list you want tasks created in.
# Shape: https://app.clickup.com/<team>/v/li/<LIST_ID>
CLICKUP_LIST_ID=
# Random 32-byte hex value. Must match the value given to ClickUp when
# registering the webhook (so ClickUp HMAC-SHA256-signs every event with it).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CLICKUP_WEBHOOK_SECRET=
# SENAITE Analysis Service keyword used as the clone template for peptide
# completions. Defaults to BPC157-ID if unset.
SENAITE_PEPTIDE_TEMPLATE_KEYWORD=BPC157-ID
# Set to "true" to enable the auto-clone side-effect when a peptide request
# completes. Requires the integration-service
#   POST /v1/internal/senaite/services/clone
# endpoint to be implemented. When false, the clone is skipped with a log
# line and a lab tech clones the template manually.
PEPTIDE_SENAITE_CLONE_ENABLED=false
# Set to "true" to enable WooCommerce coupon issuance on completion.
# When false, no coupon is issued — useful for smoke tests where you don't
# want real coupons landing in WooCommerce, or when WC keys aren't
# configured on the integration-service side yet.
PEPTIDE_COUPON_ENABLED=false
# Shared secret between Accu-Mk1 backend and integration-service for
# X-Service-Token auth on internal hops. Set BOTH names below to the same
# value — Accu-Mk1 reads the token under two different env var names:
#   * INTEGRATION_SERVICE_TOKEN — outgoing calls (integration_service_client.py)
#   * ACCUMK1_INTERNAL_SERVICE_TOKEN — incoming validation (auth.py)
# The integration-service side reads ACCUMK1_INTERNAL_SERVICE_TOKEN from
# its own env — must also be this same value.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTEGRATION_SERVICE_TOKEN=
ACCUMK1_INTERNAL_SERVICE_TOKEN=

# ============================================================
# Scale (Mettler Toledo XSR105DU — MT-SICS Ethernet)
# ============================================================
# Set SCALE_HOST to enable automatic weight capture from the balance.
# Leave commented out for manual-entry mode (no scale required).
# SCALE_HOST=192.168.3.113
# SCALE_PORT=8001

# ============================================================
# SENAITE LIMS Integration
# ============================================================
# Set SENAITE_URL to enable sample lookup in the wizard.
# Leave commented out to disable the SENAITE Lookup tab entirely.
# Docker network: http://senaite:8080
# SENAITE_URL=http://senaite:8080
# SENAITE_USER=admin
# SENAITE_PASSWORD=your_senaite_password
